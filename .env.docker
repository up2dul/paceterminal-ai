# Docker Compose Environment Variables
# Copy this file to .env before running docker-compose

# OpenAI API Key (Required)
OPENAI_API_KEY=sk-proj-xxxxx

# Tavily API Key (Required for web search)
TAVILY_API_KEY=

# Application Settings
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,https://paceterminal.com

# Rate Limiting
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_ANALYSIS=3/minute

# Database credentials (default for local development)
# These are set in docker-compose.yml but can be overridden here
# DATABASE_URL=postgresql://postgres:password@postgres:5432/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:password@postgres:5432/postgres
# REDIS_URL=redis://redis:6379/0
